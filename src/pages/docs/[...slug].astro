---
import Base from '../../layouts/Base.astro';
import CategoryTag from '../../components/CategoryTag.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allDocs = await getCollection('docs');
  // Only generate pages for non-link posts
  return allDocs
    .filter(d => !d.data.link)
    .map(doc => ({
      params: { slug: doc.id },
      props: { doc },
    }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const dateStr = doc.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const personSlug = doc.data.author.toLowerCase().replace(/\s+/g, '-');
---

<Base title={doc.data.title}>
  <article class="doc">
    <header>
      <div class="tags">
        {doc.data.categories.map(cat => <CategoryTag name={cat} />)}
      </div>
      <h1>{doc.data.title}</h1>
      <div class="meta">
        <a href={`/people/${personSlug}`} class="author">{doc.data.author}</a>
        <span class="sep">&middot;</span>
        <time>{dateStr}</time>
      </div>
    </header>

    <div class="content">
      <Content />
    </div>
  </article>
</Base>

<style>
  .doc { max-width: 780px; }
  header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .tags { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-bottom: 0.75rem; }
  h1 { font-size: 2rem; font-weight: 800; line-height: 1.2; margin-bottom: 0.75rem; }
  .meta { color: var(--text-secondary); font-size: 0.9375rem; display: flex; align-items: center; gap: 0.4rem; }
  .author { color: var(--accent); font-weight: 500; }
  .sep { color: var(--border); }

  .content { font-size: 1.0625rem; line-height: 1.75; }
  .content :global(h2) { font-size: 1.375rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .content :global(h3) { font-size: 1.125rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .content :global(p) { margin-bottom: 1rem; }
  .content :global(ul), .content :global(ol) { margin-bottom: 1rem; padding-left: 1.5rem; }
  .content :global(li) { margin-bottom: 0.375rem; }
  .content :global(code) { background: var(--bg-card); padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.9em; }
  .content :global(pre) { background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 1rem; overflow-x: auto; margin-bottom: 1rem; }
  .content :global(pre code) { background: none; padding: 0; }
  .content :global(blockquote) { border-left: 3px solid var(--accent); padding-left: 1rem; color: var(--text-secondary); margin-bottom: 1rem; }
  .content :global(table) { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
  .content :global(th), .content :global(td) { border: 1px solid var(--border); padding: 0.5rem 0.75rem; text-align: left; }
  .content :global(th) { background: var(--bg-card); font-weight: 600; }
</style>
