---
import Base from '../layouts/Base.astro';
import DocCard from '../components/DocCard.astro';
import CategoryTag from '../components/CategoryTag.astro';
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');
const sorted = allDocs.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const contributors = [...new Set(allDocs.map(d => d.data.author))];

const catCounts = new Map<string, number>();
allDocs.forEach(d => d.data.categories.forEach(c => catCounts.set(c, (catCounts.get(c) || 0) + 1)));
const categories = [...catCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Home">
  <section class="hero">
    <h1>INSEAD Claude Code</h1>
    <p>Workflows, tools, and tips from INSEAD's Claude Code community. Browse by person or by category.</p>
  </section>

  <section class="section">
    <h2>Recent</h2>
    <div class="grid">
      {sorted.slice(0, 9).map(doc => (
        <DocCard
          title={doc.data.title}
          author={doc.data.author}
          date={doc.data.date}
          description={doc.data.description}
          categories={doc.data.categories}
          type={doc.data.type}
          link={doc.data.link}
          slug={doc.id}
        />
      ))}
    </div>
  </section>

  <div class="two-col">
    <section class="section">
      <h2>Contributors</h2>
      <ul class="contributor-list">
        {contributors.map(name => {
          const slug = name.toLowerCase().replace(/\s+/g, '-');
          const count = allDocs.filter(d => d.data.author === name).length;
          return (
            <li>
              <a href={`/people/${slug}`}>{name}</a>
              <span class="count">{count} {count === 1 ? 'doc' : 'docs'}</span>
            </li>
          );
        })}
      </ul>
    </section>

    <section class="section">
      <h2>Categories</h2>
      <div class="cat-cloud">
        {categories.map(([name, count]) => (
          <span class="cat-item">
            <CategoryTag name={name} />
            <span class="count">{count}</span>
          </span>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .hero {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--text-secondary);
    font-size: 1.125rem;
    max-width: 600px;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.8125rem;
    margin-bottom: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  @media (max-width: 640px) {
    .two-col { grid-template-columns: 1fr; }
  }

  .contributor-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contributor-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .contributor-list a { font-weight: 500; }
  .count { color: var(--text-secondary); font-size: 0.75rem; }
  .cat-cloud { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .cat-item { display: inline-flex; align-items: center; gap: 0.3rem; }
</style>
