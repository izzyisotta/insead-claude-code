</nav>

<style>
  nav {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--text);
  }

  .logo:hover {
    text-decoration: none;
    color: var(--accent);
  }

  .links {
    display: flex;
    gap: 1.5rem;
  }

  .links a {
    color: var(--text-secondary);
    font-size: 0.9375rem;
  }

  .links a:hover {
    color: var(--text);
    text-decoration: none;
  }
</style>
