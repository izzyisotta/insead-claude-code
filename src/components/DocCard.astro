---
import CategoryTag from './CategoryTag.astro';

interface Props {
  title: string;
  author: string;
  date: Date;
  description: string;
  categories: string[];
  link?: string;
  slug: string;
}

const { title, author, date, description, categories, link, slug } = Astro.props;
const dateStr = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
const personSlug = slug.split('/')[0];
const isLink = !!link;
---

<article class="card">
  <div class="card-body">
    <div class="meta">
      <a href={`/people/${personSlug}`} class="author">{author}</a>
      <span class="sep">&middot;</span>
      <time>{dateStr}</time>
    </div>
    <h3>
      {isLink ? (
        <a href={link} target="_blank" rel="noopener">{title} <span class="external">&#8599;</span></a>
      ) : (
        <a href={`/docs/${slug}`}>{title}</a>
      )}
    </h3>
    <p class="description">{description}</p>
    <div class="tags">
      {categories.map((cat) => <CategoryTag name={cat} />)}
    </div>
  </div>
  {isLink && (
    <div class="card-action">
      <a href={link} target="_blank" rel="noopener" class="visit-btn">Visit</a>
    </div>
  )}
</article>

<style>
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--accent);
  }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .author {
    color: var(--accent);
    font-weight: 500;
  }

  .sep {
    color: var(--border);
  }

  h3 {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
  }

  h3 a {
    color: var(--text);
  }

  h3 a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .external {
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .description {
    color: var(--text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }

  .card-action {
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }

  .visit-btn {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: var(--accent);
    color: var(--bg);
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
  }

  .visit-btn:hover {
    background: var(--accent-hover);
    text-decoration: none;
  }
</style>
